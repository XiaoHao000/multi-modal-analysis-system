# ===== LLM 配置 =====
API_KEY=your-api-key-here
BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
VL_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ===== 数据库配置 =====
# SQLite（开发环境）:
DATABASE_URL=sqlite+aiosqlite:///sales_data.db
# PostgreSQL（生产环境）:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/data_insight
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_QUERY_TIMEOUT=10.0

# ===== Milvus 向量数据库 =====
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION_NAME=business_knowledge

# ===== LangSmith 可观测性（可选） =====
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=multi-modal-data-insight

# ===== API 安全 =====
API_CORS_ORIGINS=http://localhost:5173
# 多个来源用逗号分隔: http://localhost:5173,https://your-domain.com
API_RATE_LIMIT_PER_MINUTE=30

# ===== 鉴权（不透明 Session Token + Redis/内存 存储）=====
# 为什么不选 JWT: 单服务场景下 JWT 的无状态分布式验签是多余能力；
#   不透明 token 天然可撤销（删 key = 失效），无算法混淆攻击面，实现更简单。
# 配置 ADMIN_PASSWORD_HASH 后自动启用鉴权；留空则所有请求以 anonymous 通过
SESSION_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_USERNAME=admin
# Bcrypt 哈希，生成命令: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('admin123'))"
ADMIN_PASSWORD_HASH=

# ===== Checkpointer =====
CHECKPOINT_DB_PATH=checkpoints.db

# ===== Knowledge Base =====
# 业务知识 JSON 文件路径（留空使用默认 data/knowledge.json）
KNOWLEDGE_FILE=

# ===== Redis（Session 存储 + 分布式限流）=====
REDIS_URL=redis://localhost:6379/0

# ===== DashScope ASR（阿里云 Paraformer 语音识别，与 LLM 共用 API_KEY）=====
DASHSCOPE_ASR_MODEL=paraformer-realtime-v2
DASHSCOPE_ASR_SAMPLE_RATE=16000

# ===== Agent 配置 =====
AGENT_MAX_RETRIES=1
RAG_TOP_K=3
SQL_LIMIT=50
